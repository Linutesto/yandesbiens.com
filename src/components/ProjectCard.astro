---
import type { Project } from '../data/projects';
interface Props { project: Project; }
const { project } = Astro.props;
const statusMap = {
  live:     { label: 'live',     cls: 'st-live' },
  wip:      { label: 'wip',      cls: 'st-wip' },
  research: { label: 'research', cls: 'st-research' },
};
const st = statusMap[project.status];
---
<a class="card" href={`/projects/${project.slug}/`}>
  <div class="head">
    <span class="file">
      <span class="green">~/</span>{project.slug}
    </span>
    <span class:list={['status', st.cls]}>● {st.label}</span>
  </div>
  <h3>{project.name}{project.featured && <span class="live-3d">live 3D ↗</span>}</h3>
  <p class="tagline">{project.tagline}</p>
  <p class="desc">{project.desc}</p>
  <ul class="stack">
    {project.stack.map((s) => <li>{s}</li>)}
  </ul>
  <span class="open">cat README →</span>
</a>

<style>
  .card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel);
    padding: 18px 18px 16px;
    transition: border-color .18s, transform .18s, box-shadow .18s;
    position: relative;
    color: inherit;
  }
  .card:hover {
    border-color: var(--pink);
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -26px #ff5fd1aa, var(--glow-pink);
    text-shadow: none;
  }
  .card:hover .open { color: var(--pink); opacity: 1; }
  .live-3d {
    font-size: 10.5px; color: var(--pink); border: 1px solid var(--pink);
    border-radius: 4px; padding: 1px 6px; margin-left: 8px; vertical-align: middle;
    box-shadow: var(--glow-pink);
  }
  .open {
    display: block; margin-top: 14px; font-size: 12px;
    color: var(--green-dim); opacity: .7; transition: all .18s;
  }
  .head {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12.5px; margin-bottom: 12px;
  }
  .file { color: var(--muted); }
  .status { font-size: 11px; letter-spacing: .5px; }
  .st-live { color: var(--green); }
  .st-wip { color: var(--amber); }
  .st-research { color: var(--pink-soft); }
  h3 { margin: 0; font-size: 18px; color: var(--text); }
  .tagline { margin: 2px 0 12px; color: var(--pink); font-size: 13.5px; }
  .desc { margin: 0 0 16px; color: var(--text); font-size: 14px; }
  .stack { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 6px; }
  .stack li {
    font-size: 11.5px; color: var(--green-dim);
    border: 1px solid var(--border); border-radius: 4px;
    padding: 2px 7px; background: #ffffff05;
  }
</style>
