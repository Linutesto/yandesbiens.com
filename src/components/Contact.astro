  },
  {
    label: 'Facebook',
    handle: 'yan.desbiens.75',
    href: 'https://facebook.com/yan.desbiens.75',
    path: 'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.9h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94z',
  },
  {
    label: 'Email',
    handle: 'yandesbiens420@gmail.com',
    href: 'mailto:yandesbiens420@gmail.com',
    path: 'M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z',
  },
];
---
<div class="contact-grid">
  {contacts.map((c) => (
    <a class="contact-card" href={c.href} target={c.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener">
      <svg class="ico" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d={c.path} />
      </svg>
      <span class="who">
        <b>{c.label}</b>
        <span>{c.handle}</span>
      </span>
    </a>
  ))}
</div>
