---
import Subscribe from './Subscribe.astro';
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="wrap foot-top">
    <Subscribe variant="footer" src="footer" heading="Get every proof drop." blurb="Reproducible local-first AI research. No hype." />
  </div>
  <div class="wrap foot-bottom">
    <span class="muted">
      © {year} <span class="green">Éthiqueia Québec inc.</span> · research by Yan Desbiens
    </span>
    <div class="socials">
      <a href="/research">research</a>
      <span class="sep">·</span>
      <a href="/graph">graph</a>
      <span class="sep">·</span>
      <a href="/status">status</a>
      <span class="sep">·</span>
      <a href="/timeline">timeline</a>
      <span class="sep">·</span>
      <a href="/newsletter">newsletter</a>
      <span class="sep">·</span>
      <a href="/blog">blog</a>
      <span class="sep">·</span>
      <a href="/cite">cite</a>
      <span class="sep">·</span>
      <a href="https://github.com/linutesto" target="_blank" rel="noopener">github</a>
      <span class="sep">·</span>
      <a href="mailto:yandesbiens420@gmail.com">email</a>
      <span class="sep">·</span>
      <a href="/rss.xml">rss</a>
    </div>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 26px 0 40px;
    font-size: 13px;
  }
  .foot-top { max-width: 520px; margin-bottom: 26px; }
  .foot-bottom {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    align-items: baseline;
  }
  .socials a { color: var(--muted); }
  .socials a:hover { color: var(--pink); }
  .sep { color: var(--border); margin: 0 4px; }
</style>
