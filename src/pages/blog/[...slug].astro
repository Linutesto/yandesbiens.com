---
import Base from '../../layouts/Base.astro';
import Subscribe from '../../components/Subscribe.astro';
import Cite from '../../components/Cite.astro';
import { getCollection, render } from 'astro:content';
import { tracks } from '../../data/tracks';
import { SITE } from '../../data/site';
import { getPublicationBySlug } from '../../data/publications';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const track = post.data.track ? tracks[post.data.track] : null;
const pub = getPublicationBySlug(post.id);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.org },
  mainEntityOfPage: new URL(`/blog/${post.id}/`, SITE.url).href,
  ...(post.data.ogImage ? { image: new URL(post.data.ogImage, SITE.url).href } : {}),
  keywords: post.data.tags.join(', '),
};
---
<Base
  title={`${post.data.title} — yan desbiens`}
  description={post.data.description}
  type="article"
  publishDate={post.data.date}
  tags={post.data.tags}
  ogImage={post.data.ogImage}
  jsonLd={jsonLd}
>
  <p class="prompt">
    <b>yan@yandesbiens</b>:<span class="path">~/blog</span>$ <span class="cmd">cat {post.id}.md</span>
  </p>

  <article class="post">
    {(post.data.proofDrop || track) && (
      <p class="kicker">
        {post.data.proofDrop && <span class="pd">proof drop</span>}
        {track && <a class="track" href={`/research#${track.id}`} style={`color:${track.accent}`}>{track.label}</a>}
      </p>
    )}
    <h1>{post.data.title}</h1>
    <p class="meta">
      <span class="date">{post.data.date.toISOString().slice(0, 10)}</span>
      {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
    </p>
    <div class="body">
      <Content />
    </div>
  </article>

  {pub && <Cite pub={pub} />}

  <Subscribe variant="page" src={`blog-${post.id}`}
    heading="Get the next proof drop."
    blurb="Reproducible local-first AI research, in your inbox. No hype." />

  <p class="more"><a href="/blog">← back to all posts</a></p>
</Base>

<style>
  .post { max-width: 72ch; }
  .kicker { display: flex; gap: 10px; align-items: center; margin: 8px 0 0; font-size: 12px; }
  .kicker .pd {
    color: #1a0014; background: var(--pink); border-radius: 999px; padding: 2px 9px;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .kicker .track { text-decoration: none; }
  .post h1 { color: var(--green); font-size: 26px; margin: 10px 0 6px; text-shadow: var(--glow-green); }
  .meta { display: flex; gap: 12px; align-items: center; margin: 0 0 26px; font-size: 13px; flex-wrap: wrap; }
  .meta .date { color: var(--green-dim); }
  .meta .tag { color: var(--pink); }
  .body :global(h2) { color: var(--pink); margin-top: 32px; }
  .body :global(h3) { color: var(--green); }
  .body :global(a) { text-decoration: underline; }
  .body :global(img) {
    max-width: 100%; height: auto; border: 1px solid var(--border);
    border-radius: 8px; margin: 18px 0; background: var(--bg-soft);
  }
  .body :global(table) {
    width: 100%; border-collapse: collapse; margin: 18px 0; font-size: 13.5px;
  }
  .body :global(th), .body :global(td) {
    border: 1px solid var(--border); padding: 7px 10px; text-align: left;
  }
  .body :global(th) { color: var(--green); background: #ffffff06; }
  .body :global(code) {
    background: #ffffff0c; border: 1px solid var(--border);
    border-radius: 4px; padding: 1px 5px; font-size: 13px; color: var(--amber);
  }
  .body :global(pre) {
    background: var(--bg-soft); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; overflow-x: auto;
  }
  .body :global(pre code) { background: none; border: none; padding: 0; color: var(--text); }
  .body :global(blockquote) {
    border-left: 2px solid var(--pink); margin: 0; padding-left: 16px; color: var(--muted);
  }
  .more { margin-top: 36px; }
</style>
