---
import Base from '../layouts/Base.astro';
import Cite from '../components/Cite.astro';
import { publications, ORG } from '../data/publications';
import { tracks } from '../data/tracks';

const sorted = [...publications].sort((a, b) => b.date.localeCompare(a.date));

const labBib = `@misc{ethiqueia,
  title = {Éthiqueia — independent AI research},
  author = {Yan Desbiens},
  institution = {${ORG}},
  howpublished = {\\url{https://yandesbiens.com}},
  note = {Reproducible local-first AI research}
}`;
---
<Base
  title="citations — Yan Desbiens · Éthiqueia"
  description="How to cite the Éthiqueia research program and its reproducible proof drops. BibTeX, APA, and CITATION.cff for every output."
>
  <p class="prompt">
    <b>yan@yandesbiens</b>:<span class="path">~</span>$ <span class="cmd">cat citations.bib</span>
  </p>

  <header class="chead">
    <h1>Citations</h1>
    <p class="sub">
      Every output here is meant to be a <span class="green">permanent, citable scientific
      asset</span>. If a result helped your work, please cite it — that's how a small lab
      compounds. Outputs are reproducible or marked speculative; none are opinions.
    </p>
  </header>

  <h2 class="sec">// citing the lab</h2>
  <p class="muted small">Author: <b>Yan Desbiens</b> · Affiliation: <b>{ORG}, Québec, Canada</b></p>
  <pre class="bib"><code>{labBib}</code></pre>

  <h2 class="sec">// citable outputs ({sorted.length})</h2>
  {sorted.map((p) => (
    <article class="pub">
      <div class="pub-top">
        <a class="pub-title" href={p.url}>{p.title}</a>
        <span class="pub-track" style={`color:${tracks[p.track].accent}`}>{tracks[p.track].label}</span>
      </div>
      <p class="pub-meta">
        {p.authors.join(', ')} · {p.date} · <span class="ty">{p.type}</span>
        {p.version && <> · {p.version}</>}
      </p>
      <p class="pub-abs">{p.abstract}</p>
      <p class="pub-art">
        {p.artifacts.map((a, i) => (
          <>{i > 0 && ' · '}<a href={a.href} target={a.href.startsWith('http') ? '_blank' : undefined} rel="noopener">{a.label}</a></>
        ))}
      </p>
      <Cite pub={p} />
    </article>
  ))}

  <p class="muted small note">
    DOIs are minted per release via Zenodo as outputs stabilize; until then, cite the canonical
    URL + version. Machine-readable <code>CITATION.cff</code> ships in each repository.
  </p>
</Base>

<style>
  .chead h1 { color: var(--green); font-size: 26px; text-shadow: var(--glow-green); margin: 6px 0; }
  .sub { color: var(--text); max-width: 72ch; }
  .sec { color: var(--pink); margin: 30px 0 10px; font-size: 15px; }
  .small { font-size: 13px; }
  .bib { background: var(--bg-soft); border: 1px solid var(--border); border-radius: 6px; padding: 12px; overflow-x: auto; font-size: 12.5px; }
  .pub { border-top: 1px solid var(--border); padding: 18px 0; }
  .pub-top { display: flex; gap: 12px; justify-content: space-between; align-items: baseline; flex-wrap: wrap; }
  .pub-title { color: var(--green); font-size: 17px; text-decoration: none; }
  .pub-title:hover { text-shadow: var(--glow-green); }
  .pub-track { font-size: 12px; }
  .pub-meta { color: var(--muted); font-size: 12.5px; margin: 4px 0; }
  .pub-meta .ty { color: var(--amber); }
  .pub-abs { color: var(--text); font-size: 13.5px; max-width: 74ch; }
  .pub-art { font-size: 13px; }
  .note { margin-top: 24px; }
</style>
