---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}
const {
  title = 'yan desbiens — AI systems builder',
  description = SITE.description,
  ogImage = SITE.defaultOg,
  type = 'website',
  publishDate,
  tags = [],
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogUrl = new URL(ogImage, SITE.url).href;

// Default JSON-LD: the lab as an Organization founded by Yan.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.org,
  alternateName: SITE.orgShort,
  url: SITE.url,
  founder: { '@type': 'Person', name: SITE.name },
  description: SITE.description,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#07090c" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:site_name" content={`${SITE.name} · ${SITE.orgShort}`} />
    {type === 'article' && publishDate && (
      <meta property="article:published_time" content={publishDate.toISOString()} />
    )}
    {tags.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="All posts" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Proof drops" href="/rss/benchmarks.xml" />
    <link rel="alternate" type="application/rss+xml" title="Research" href="/rss/research.xml" />
    <link rel="alternate" type="application/rss+xml" title="Newsletter" href="/rss/newsletter.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? orgLd)} />

    {SITE.cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${SITE.cfAnalyticsToken}"}`}
      ></script>
    )}
  </head>
  <body>
    <Nav />
    <main class="wrap">
      <slot />
    </main>
    <Footer />
  </body>
</html>
